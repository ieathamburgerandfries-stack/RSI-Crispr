# ============================================================
# 3. Helper functions
# ============================================================

def stable_spearman(y_true, y_pred):
    rho = spearmanr(y_true, y_pred)[0]
    if np.isnan(rho):
        return 0.0
    return rho


def stable_pearson(y_true, y_pred):
    r = pearsonr(y_true, y_pred)[0]
    if np.isnan(r):
        return 0.0
    return r


def feature_name_hash(feature_names):
    payload = json.dumps(list(feature_names), separators=(",", ":"), ensure_ascii=False)
    return hashlib.sha256(payload.encode("utf-8")).hexdigest()


def safe_divide(numerator, denominator):
    return numerator / (denominator + 1e-9)


def get_existing_numeric_column(df, colname):
    if colname in df.columns:
        return pd.to_numeric(df[colname], errors="coerce")
    return pd.Series(np.nan, index=df.index)


def nucleotide_count_column(base):
    return f"{base}sgRNA.raw"


def dinucleotide_count_column(dinuc):
    return f"{dinuc}sgRNA.raw"


def median_impute_train_val(X_train, X_val):
    """
    Median imputation fitted on training fold only.
    This avoids validation leakage.
    """
    X_train = X_train.astype(np.float32, copy=True)
    X_val = X_val.astype(np.float32, copy=True)

    medians = np.nanmedian(X_train, axis=0)
    medians = np.where(np.isnan(medians), 0.0, medians)

    train_nan_rows, train_nan_cols = np.where(np.isnan(X_train))
    val_nan_rows, val_nan_cols = np.where(np.isnan(X_val))

    X_train[train_nan_rows, train_nan_cols] = medians[train_nan_cols]
    X_val[val_nan_rows, val_nan_cols] = medians[val_nan_cols]

    return X_train, X_val


# ============================================================
# 4. Create simple sgRNA secondary-structure proxy features
# ============================================================

def make_sgrna_structure_proxy_features(X_df_numeric):
    """
    Creates simple sgRNA secondary-structure proxy features from available
    nucleotide and dinucleotide counts.

    These are NOT full RNA folding calculations.
    They are lightweight proxy descriptors for:
      - GC/AT balance
      - nucleotide entropy
      - dinucleotide entropy
      - reverse-complement balance
      - palindromic dinucleotide content
      - approximate hairpin/self-complementarity tendency
      - interactions with existing sgRNA.gc / sgRNA.structure / sgRNA.temp columns
    """

    engineered = {}

    # ------------------------------------------------------------
    # 1. Mononucleotide counts
    # ------------------------------------------------------------

    mono = {}

    for base in BASES:
        col = nucleotide_count_column(base)
        mono[base] = get_existing_numeric_column(X_df_numeric, col)

    A = mono["A"]
    C = mono["C"]
    G = mono["G"]
    T = mono["T"]

    total_nt = A + C + G + T

    engineered["ssproxy_A_fraction"] = safe_divide(A, total_nt)
    engineered["ssproxy_C_fraction"] = safe_divide(C, total_nt)
    engineered["ssproxy_G_fraction"] = safe_divide(G, total_nt)
    engineered["ssproxy_T_fraction"] = safe_divide(T, total_nt)

    gc_count = G + C
    at_count = A + T
    purine_count = A + G
    pyrimidine_count = C + T

    gc_fraction = safe_divide(gc_count, total_nt)
    at_fraction = safe_divide(at_count, total_nt)

    engineered["ssproxy_gc_fraction_from_counts"] = gc_fraction
    engineered["ssproxy_at_fraction_from_counts"] = at_fraction
    engineered["ssproxy_purine_fraction"] = safe_divide(purine_count, total_nt)
    engineered["ssproxy_pyrimidine_fraction"] = safe_divide(pyrimidine_count, total_nt)

    engineered["ssproxy_gc_skew"] = safe_divide(G - C, G + C)
    engineered["ssproxy_at_skew"] = safe_divide(A - T, A + T)

    mono_matrix = np.vstack([
        engineered["ssproxy_A_fraction"],
        engineered["ssproxy_C_fraction"],
        engineered["ssproxy_G_fraction"],
        engineered["ssproxy_T_fraction"],
    ]).T.astype(np.float32)

    mono_matrix_for_entropy = np.where(mono_matrix > 0, mono_matrix, 1e-9)
    nt_entropy = -np.sum(mono_matrix_for_entropy * np.log2(mono_matrix_for_entropy), axis=1)

    engineered["ssproxy_nucleotide_entropy"] = nt_entropy
    engineered["ssproxy_max_base_fraction"] = np.nanmax(mono_matrix, axis=1)
    engineered["ssproxy_base_fraction_std"] = np.nanstd(mono_matrix, axis=1)

    # Approximate duplex/folding strength:
    # GC pairs are stronger than AT pairs, so this is a crude binding-strength proxy.
    engineered["ssproxy_simple_pairing_strength_proxy"] = safe_divide(
        2.0 * gc_count + 1.0 * at_count,
        total_nt,
    )

    engineered["ssproxy_simple_mfe_proxy_negative_strength"] = -engineered[
        "ssproxy_simple_pairing_strength_proxy"
    ]

    # ------------------------------------------------------------
    # 2. Dinucleotide counts
    # ------------------------------------------------------------

    dinuc_counts = {}

    for dinuc in DINUCS:
        col = dinucleotide_count_column(dinuc)
        dinuc_counts[dinuc] = get_existing_numeric_column(X_df_numeric, col)

    dinuc_total = sum(dinuc_counts.values())

    for dinuc in DINUCS:
        engineered[f"ssproxy_dinuc_{dinuc}_fraction"] = safe_divide(
            dinuc_counts[dinuc],
            dinuc_total,
        )

    dinuc_fraction_matrix = np.vstack([
        engineered[f"ssproxy_dinuc_{dinuc}_fraction"] for dinuc in DINUCS
    ]).T.astype(np.float32)

    dinuc_for_entropy = np.where(dinuc_fraction_matrix > 0, dinuc_fraction_matrix, 1e-9)
    dinuc_entropy = -np.sum(dinuc_for_entropy * np.log2(dinuc_for_entropy), axis=1)

    engineered["ssproxy_dinucleotide_entropy"] = dinuc_entropy
    engineered["ssproxy_max_dinucleotide_fraction"] = np.nanmax(dinuc_fraction_matrix, axis=1)
    engineered["ssproxy_dinucleotide_fraction_std"] = np.nanstd(dinuc_fraction_matrix, axis=1)

    # Palindromic/self-reverse-complement dinucleotides.
    palindromic_dinucs = ["AT", "TA", "CG", "GC"]
    engineered["ssproxy_palindromic_dinuc_fraction"] = safe_divide(
        sum(dinuc_counts[d] for d in palindromic_dinucs),
        dinuc_total,
    )

    # GC-heavy and AT-heavy dinucleotide fractions.
    gc_heavy_dinucs = ["GC", "CG", "GG", "CC"]
    at_heavy_dinucs = ["AT", "TA", "AA", "TT"]

    engineered["ssproxy_gc_heavy_dinuc_fraction"] = safe_divide(
        sum(dinuc_counts[d] for d in gc_heavy_dinucs),
        dinuc_total,
    )

    engineered["ssproxy_at_heavy_dinuc_fraction"] = safe_divide(
        sum(dinuc_counts[d] for d in at_heavy_dinucs),
        dinuc_total,
    )

    # ------------------------------------------------------------
    # 3. Reverse-complement balance proxy
    # ------------------------------------------------------------
    # This approximates whether the sequence composition contains many
    # complementary short motifs, which may reflect self-complementarity risk.

    visited = set()
    rc_balance_score = pd.Series(0.0, index=X_df_numeric.index)

    for dinuc in DINUCS:
        if dinuc in visited:
            continue

        rc = REVCOMP_DINUC[dinuc]
        visited.add(dinuc)
        visited.add(rc)

        if dinuc == rc:
            rc_balance_score = rc_balance_score + dinuc_counts[dinuc]
        else:
            rc_balance_score = rc_balance_score + np.minimum(
                dinuc_counts[dinuc],
                dinuc_counts[rc],
            )

    rc_balance_fraction = safe_divide(rc_balance_score, dinuc_total)

    engineered["ssproxy_reverse_complement_dinuc_balance"] = rc_balance_fraction

    # A crude hairpin-risk proxy:
    # self-complementary motif balance × GC fraction × dinucleotide concentration imbalance.
    engineered["ssproxy_hairpin_risk_proxy"] = (
        rc_balance_fraction
        * gc_fraction
        * engineered["ssproxy_max_dinucleotide_fraction"]
    )

    # Another crude self-structure proxy:
    # high GC + low entropy can mean a more compositionally biased guide.
    engineered["ssproxy_gc_low_entropy_structure_proxy"] = gc_fraction * (
        2.0 - engineered["ssproxy_nucleotide_entropy"]
    )

    # ------------------------------------------------------------
    # 4. Interactions with existing benchmark sgRNA-level features
    # ------------------------------------------------------------
    # These columns are already in the baseline, but interactions are new.
    # They test whether structure/temperature/GC relationships matter jointly.

    sgRNA_gc = get_existing_numeric_column(X_df_numeric, "sgRNA.gcsgRNA.raw")
    sgRNA_structure = get_existing_numeric_column(X_df_numeric, "sgRNA.structuresgRNA.raw")
    sgRNA_temp = get_existing_numeric_column(X_df_numeric, "sgRNA.tempsgRNA.raw")

    engineered["ssproxy_existing_gc_x_structure"] = sgRNA_gc * sgRNA_structure
    engineered["ssproxy_existing_gc_x_temp"] = sgRNA_gc * sgRNA_temp
    engineered["ssproxy_existing_structure_x_temp"] = sgRNA_structure * sgRNA_temp

    engineered["ssproxy_structure_x_rc_balance"] = sgRNA_structure * rc_balance_fraction
    engineered["ssproxy_temp_x_gc_fraction"] = sgRNA_temp * gc_fraction
    engineered["ssproxy_temp_x_hairpin_risk"] = sgRNA_temp * engineered["ssproxy_hairpin_risk_proxy"]

    # ------------------------------------------------------------
    # 5. Convert to DataFrame and clean
    # ------------------------------------------------------------

    engineered_df = pd.DataFrame(engineered)

    engineered_df = engineered_df.replace([np.inf, -np.inf], np.nan)

    print("\n" + "=" * 90)
    print("CREATING SIMPLE sgRNA SECONDARY-STRUCTURE PROXY FEATURES")
    print("=" * 90)
    print(f"Created engineered structure proxy features: {engineered_df.shape[1]}")

    print("\nFirst 30 engineered features:")
    for name in list(engineered_df.columns[:30]):
        print(" -", name)

    print("\nFeature summary preview:")
    print(engineered_df.describe().T[["mean", "std", "min", "max"]].head(20))

    print("=" * 90)

    return engineered_df


# ============================================================
# 5. Leakage-safe CV
# ============================================================

def leakage_safe_cv(X_array, y_array, feature_names, label, engineered_start_index=None):
    """
    Standardised leakage-safe CV:
    1. Split train/validation.
    2. Fit imputer on training fold only.
    3. Fit feature selector on training fold only.
    4. Select top 300 features.
    5. Train XGBoost.
    6. Evaluate validation fold.
    """

    selector_params = dict(
        n_estimators=300,
        learning_rate=0.05,
        max_depth=4,
        subsample=0.8,
        colsample_bytree=0.8,
        reg_alpha=0.0,
        reg_lambda=1.0,
        min_child_weight=1,
        random_state=RANDOM_STATE,
        n_jobs=-1,
        tree_method="hist",
        importance_type="gain",
    )

    model_params = dict(
        n_estimators=N_ESTIMATORS,
        learning_rate=0.05,
        max_depth=4,
        subsample=0.8,
        colsample_bytree=0.8,
        reg_alpha=0.0,
        reg_lambda=1.0,
        min_child_weight=1,
        random_state=RANDOM_STATE,
        n_jobs=-1,
        tree_method="hist",
    )

    kf = KFold(
        n_splits=N_SPLITS,
        shuffle=True,
        random_state=RANDOM_STATE,
    )

    fold_records = []
    engineered_feature_counter = Counter()

    print("\n" + "=" * 90)
    print(f"STARTING LEAKAGE-SAFE CV: {label}")
    print("=" * 90)
    print(f"X shape: {X_array.shape}")
    print(f"Feature count: {len(feature_names)}")
    print(f"Feature hash: {feature_name_hash(feature_names)}")

    for fold_id, (train_idx, val_idx) in enumerate(kf.split(X_array), start=1):

        X_train_raw = X_array[train_idx]
        X_val_raw = X_array[val_idx]
        y_train = y_array[train_idx]
        y_val = y_array[val_idx]

        # 1. Fold-internal imputation
        X_train, X_val = median_impute_train_val(X_train_raw, X_val_raw)

        # 2. Fold-internal feature ranking
        selector = xgb.XGBRegressor(**selector_params)
        selector.fit(X_train, y_train)

        importances = selector.feature_importances_
        ranked_indices = np.argsort(importances)[::-1]
        selected_indices = ranked_indices[:FINAL_N_FEATURES]

        selected_engineered_names = []

        if engineered_start_index is not None:
            selected_engineered_indices = [
                idx for idx in selected_indices if idx >= engineered_start_index
            ]
            selected_engineered_names = [
                feature_names[idx] for idx in selected_engineered_indices
            ]

            for name in selected_engineered_names:
                engineered_feature_counter[name] += 1

        # 3. Train final model on selected features
        X_train_selected = X_train[:, selected_indices]
        X_val_selected = X_val[:, selected_indices]

        model = xgb.XGBRegressor(**model_params)
        model.fit(X_train_selected, y_train)

        preds = model.predict(X_val_selected)

        fold_r2 = r2_score(y_val, preds)
        fold_spearman = stable_spearman(y_val, preds)
        fold_pearson = stable_pearson(y_val, preds)
        fold_mse = mean_squared_error(y_val, preds)

        fold_records.append({
            "model_label": label,
            "fold": fold_id,
            "r2": fold_r2,
            "spearman": fold_spearman,
            "pearson": fold_pearson,
            "mse": fold_mse,
            "n_engineered_features_selected": len(selected_engineered_names),
            "selected_engineered_features": " | ".join(selected_engineered_names),
        })

        print(
            f"Fold {fold_id}: "
            f"R2={fold_r2:.4f}, "
            f"Spearman={fold_spearman:.4f}, "
            f"Pearson={fold_pearson:.4f}, "
            f"MSE={fold_mse:.4f}, "
            f"engineered selected={len(selected_engineered_names)}"
        )

    fold_df = pd.DataFrame(fold_records)

    summary = {
        "model_label": label,
        "n_samples": int(X_array.shape[0]),
        "n_features_total": int(X_array.shape[1]),
        "n_features_selected": FINAL_N_FEATURES,
        "n_estimators": N_ESTIMATORS,
        "mean_r2": float(fold_df["r2"].mean()),
        "std_r2": float(fold_df["r2"].std(ddof=0)),
        "mean_spearman": float(fold_df["spearman"].mean()),
        "std_spearman": float(fold_df["spearman"].std(ddof=0)),
        "mean_pearson": float(fold_df["pearson"].mean()),
        "std_pearson": float(fold_df["pearson"].std(ddof=0)),
        "mean_mse": float(fold_df["mse"].mean()),
        "std_mse": float(fold_df["mse"].std(ddof=0)),
        "mean_engineered_features_selected": float(fold_df["n_engineered_features_selected"].mean()),
    }

    print("\nSummary:")
    print(f"Mean R2:       {summary['mean_r2']:.4f} ± {summary['std_r2']:.4f}")
    print(f"Mean Spearman: {summary['mean_spearman']:.4f} ± {summary['std_spearman']:.4f}")
    print(f"Mean Pearson:  {summary['mean_pearson']:.4f} ± {summary['std_pearson']:.4f}")
    print(f"Mean MSE:      {summary['mean_mse']:.4f} ± {summary['std_mse']:.4f}")
    print(f"Mean engineered features selected: {summary['mean_engineered_features_selected']:.2f}")

    return summary, fold_df, engineered_feature_counter


